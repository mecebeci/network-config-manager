# Network Device Credentials
# Default username for SSH connections to network devices
# This will be used if a device doesn't specify its own username in the inventory
DEVICE_USERNAME=admin

# Default password for SSH connections to network devices
# This will be used if a device doesn't specify its own password in the inventory
# SECURITY NOTE: Never commit the actual .env file with real credentials to git
DEVICE_PASSWORD=admin

# SNMP Configuration
# SNMP community string for read-only access to network devices
# Default is typically "public" but should be changed for production environments
SNMP_COMMUNITY=public

# SNMP version to use (1, 2c, or 3)
# Version 2c is most commonly used for basic monitoring
SNMP_VERSION=2c

# Optional Settings
# Logging level for application output
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG provides the most verbose output for troubleshooting
LOG_LEVEL=INFO

# Directory for storing configuration backups
# Can be absolute or relative path
# Default: configs/backups/
BACKUP_DIR=configs/backups

# Directory for storing generated reports and charts
# Can be absolute or relative path
# Default: reports/
REPORTS_DIR=reports

# Directory for application logs
# Can be absolute or relative path
# Default: logs/
LOGS_DIR=logs

# SSH connection timeout in seconds
# How long to wait for device connection before timing out
SSH_TIMEOUT=30

# Command execution timeout in seconds
# How long to wait for command output before timing out
COMMAND_TIMEOUT=60

# SNMP timeout in seconds
# How long to wait for SNMP responses before timing out
SNMP_TIMEOUT=10

# Maximum number of SNMP retries
# Number of times to retry SNMP queries on failure
SNMP_RETRIES=3
